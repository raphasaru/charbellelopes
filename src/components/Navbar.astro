---
import { Menu, X } from '@lucide/astro';
import LanguageToggle from './LanguageToggle.astro';
import type { Language } from '../i18n/utils';

interface Props {
  lang: Language;
  t: any;
}

const { lang, t } = Astro.props;
const basePath = lang === 'pt-br' ? '/pt-br' : '';

const navLinks = [
  { href: `${basePath}/#home`, label: t.nav.home },
  { href: `${basePath}/#about`, label: t.nav.about },
  { href: `${basePath}/#portfolio`, label: t.nav.portfolio },
  { href: `${basePath}/#process`, label: t.nav.process },
  { href: `${basePath}/#contact`, label: t.nav.contact },
];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href={basePath || '/'} class="flex-shrink-0">
        <img
          src="/images/logo-charbelle.png"
          alt="Charbelle Lopes"
          class="h-12 w-auto"
        />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="nav-link text-sm font-medium hover:text-magenta transition-colors duration-200 tracking-wide uppercase"
            style="color: #FDF6F9;"
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right side: Language Toggle + Mobile Menu Button -->
      <div class="flex items-center gap-4">
        <LanguageToggle lang={lang} />

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 hover:text-magenta transition-colors menu-btn"
          style="color: #FDF6F9;"
          aria-label="Toggle menu"
        >
          <Menu class="w-6 h-6 menu-open-icon" />
          <X class="w-6 h-6 menu-close-icon hidden" />
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- Mobile Menu Drawer - fora do header para evitar backdrop-filter como containing block -->
<div id="mobile-menu" class="md:hidden fixed inset-0 z-40 pointer-events-none">
  <div class="mobile-backdrop absolute inset-0 bg-plum/50 opacity-0 transition-opacity duration-300"></div>
  <div class="mobile-drawer absolute top-0 right-0 h-full w-72 bg-blush shadow-2xl">
    <div class="pt-24 px-6">
      <nav class="flex flex-col gap-4">
        {navLinks.map((link, index) => (
          <a
            href={link.href}
            class="mobile-nav-link py-3 text-lg font-medium text-plum hover:text-magenta transition-colors border-b border-lilac"
            style={`transition-delay: ${index * 50}ms`}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</div>

<style>
  #navbar {
    background: transparent;
  }

  #navbar.scrolled {
    background: rgba(253, 246, 249, 0.95);
    backdrop-filter: blur(10px);
    box-shadow: 0 2px 20px rgba(61, 38, 56, 0.08);
  }

  #navbar.scrolled .nav-link {
    color: #3D2638 !important;
  }

  #navbar.scrolled .menu-btn {
    color: #3D2638 !important;
  }

  #mobile-menu.open {
    pointer-events: auto;
  }

  #mobile-menu.open .mobile-backdrop {
    opacity: 1;
  }

  .mobile-drawer {
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  #mobile-menu.open .mobile-drawer {
    transform: translateX(0);
  }

  .mobile-nav-link {
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 0.3s ease, transform 0.3s ease, color 0.2s ease;
  }

  #mobile-menu.open .mobile-nav-link {
    opacity: 1;
    transform: translateX(0);
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuOpenIcon = document.querySelector('.menu-open-icon');
  const menuCloseIcon = document.querySelector('.menu-close-icon');
  const mobileBackdrop = document.querySelector('.mobile-backdrop');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

  // Scroll effect
  function handleScroll() {
    if (window.scrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll);
  handleScroll(); // Initial check

  // Mobile menu toggle
  function toggleMobileMenu() {
    const isOpen = mobileMenu?.classList.contains('open');

    if (isOpen) {
      mobileMenu?.classList.remove('open');
      menuOpenIcon?.classList.remove('hidden');
      menuCloseIcon?.classList.add('hidden');
      document.body.style.overflow = '';
    } else {
      mobileMenu?.classList.add('open');
      menuOpenIcon?.classList.add('hidden');
      menuCloseIcon?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
  }

  mobileMenuBtn?.addEventListener('click', toggleMobileMenu);
  mobileBackdrop?.addEventListener('click', toggleMobileMenu);

  mobileNavLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (mobileMenu?.classList.contains('open')) {
        toggleMobileMenu();
      }
    });
  });
</script>
